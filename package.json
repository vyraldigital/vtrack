{
  "name": "vtrack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "generate-icons": "node scripts/generate-icons.mjs",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.vyral.vtrack",
    "productName": "vTrack",
    "copyright": "Copyright © 2025 Vyral Digital",
    "directories": {
      "output": "dist-packaged"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "icon": "build/icon.ico",
      "signtoolOptions": {
        "publisherName": "Vyral Digital",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh",
      "shortcutName": "vTrack",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "vyraldigital",
      "repo": "vtrack",
      "private": false,
      "releaseType": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**",
      "**/node_modules/get-windows/**"
    ]
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.3.0",
    "electron-updater": "^6.8.3",
    "get-windows": "^9.3.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
